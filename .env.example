# Hugging Face (optional; faster/more reliable dataset download)
# HF_TOKEN=hf_your_token_here

# Nebius Token Factory (OpenAI-compatible API)
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Models (adjust to models available in your course)
# List models: python scripts/list_nebius_models.py
ROUTER_MODEL=google/gemma-3-27b-it
AGENT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Data paths (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_PATH=data/processed/bitext_clean.parquet
DATA_METADATA_PATH=data/processed/metadata.json
DATA_AUGMENTED_PATH=data/processed/bitext_augmented.parquet
DATA_QUALITY_REPORT_PATH=data/processed/quality_report.json
# Optional — generated by scripts/fill_placeholders.py and scripts/augment_conversations.py
# DATA_FILLED_PATH=data/processed/bitext_filled.parquet
# DATA_CONVERSATIONS_PATH=data/processed/bitext_conversations.jsonl

# Agent runtime
MAX_ITERATIONS=12
CHECKPOINT_DB_PATH=data/checkpoints.sqlite
